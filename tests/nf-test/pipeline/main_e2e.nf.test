nextflow_pipeline {

    name "Pipeline E2E Liu_2021_QUICK"
    tag "e2e"
    script "../../../main.nf"
    options "-entry test"

    test("runs Liu_2021_QUICK end-to-end") {

        when {
            params {
                test_run = false
                twofast2q_folder = "/g/typas/Personal_Folders/Nic/barseq_analysis/other_data/Liu_2021/data_cleaned/2fast2q_like_barcode_counts"
                sample_goodbarcodes_library_map = "/g/typas/Personal_Folders/Nic/barseq_analysis/data/sample_goodbarcodesfile_maps/Liu_2021/Liu_2021_QUICK.csv"
                comparisons = "/g/typas/Personal_Folders/Nic/barseq_analysis/data/comparison_files/Liu_2021/Liu_2021_comparisons_QUICK.json"
                outdir = "${projectDir}/tests/results/e2e_liu_2021_quick"
                singularity = true
                conda = false
                stop_after_barcode_extraction = false
                enable_ptr_correction = true
                minimum_read_sum_for_qc = 10000
                minimum_median_barcode_count = 1
                mbarq_normalization = "median"
                remove_all_0_barcodes = true
                lowly_abundant_barcode_cutoff = 5
                filter_on_what = "controls"
            }
        }

        then {
            assert workflow.success

            def preStatus = path("${params.outdir}/comparisons_status/comparisons_status_before_barseq_qc.tsv")
            def postStatus = path("${params.outdir}/comparisons_status/comparisons_status_after_barseq_qc.tsv")
            def traceSummary = path("${params.outdir}/comparisons_status/comparison_trace_summary.txt")
            def finalMaster = path("${params.outdir}/final_master_log.tsv")

            assert preStatus.exists()
            assert postStatus.exists()
            assert traceSummary.exists()
            assert finalMaster.exists()

            assert preStatus.readLines().size() > 1
            assert postStatus.readLines().size() > 1
            assert traceSummary.text.contains("Comparison Filtering Trace")
            assert finalMaster.readLines().size() > 1
        }
    }
}
